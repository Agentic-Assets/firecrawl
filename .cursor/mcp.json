{
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=fhqycqubkkrdgzswccwd&read_only=true&features=docs,database,debugging,development,functions,storage",
      "headers": {
        "Authorization": "Bearer ${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "Github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "firecrawl-local": {
      "command": "bash",
      "args": [
        "scripts/firecrawl-ops/firecrawl_mcp.sh"
      ]
    }
  }
}
