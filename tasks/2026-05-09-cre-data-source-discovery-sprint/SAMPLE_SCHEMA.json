{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CRE Prospecting Source Extract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "property_name": { "type": ["string", "null"] },
    "address": { "type": ["string", "null"] },
    "city": { "type": ["string", "null"] },
    "state": { "type": ["string", "null"] },
    "asset_type": { "type": ["string", "null"] },
    "size": { "type": ["string", "null"] },
    "units": { "type": ["string", "null"] },
    "year_built": { "type": ["string", "null"] },
    "owner": { "type": ["string", "null"] },
    "manager": { "type": ["string", "null"] },
    "broker": { "type": ["string", "null"] },
    "lender": { "type": ["string", "null"] },
    "tenant": { "type": ["string", "null"] },
    "listing_status": { "type": ["string", "null"] },
    "asking_price": { "type": ["string", "null"] },
    "sale_price": { "type": ["string", "null"] },
    "cap_rate": { "type": ["string", "null"] },
    "NOI": { "type": ["string", "null"] },
    "occupancy": { "type": ["string", "null"] },
    "lease_expiration": { "type": ["string", "null"] },
    "debt_maturity": { "type": ["string", "null"] },
    "distress_signal": { "type": ["string", "null"] },
    "disposition_signal": { "type": ["string", "null"] },
    "source_url": { "type": "string", "format": "uri" },
    "source_type": { "type": "string" },
    "document_url": { "type": ["string", "null"], "format": "uri" },
    "extracted_text_snippet": { "type": "string" },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "crawl_date": { "type": "string", "format": "date-time" },
    "compliance_notes": { "type": "string" }
  },
  "required": [
    "property_name",
    "address",
    "city",
    "state",
    "asset_type",
    "size",
    "units",
    "year_built",
    "owner",
    "manager",
    "broker",
    "lender",
    "tenant",
    "listing_status",
    "asking_price",
    "sale_price",
    "cap_rate",
    "NOI",
    "occupancy",
    "lease_expiration",
    "debt_maturity",
    "distress_signal",
    "disposition_signal",
    "source_url",
    "source_type",
    "document_url",
    "extracted_text_snippet",
    "confidence_score",
    "crawl_date",
    "compliance_notes"
  ]
}

